<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Management - PPSU</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.3rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.01em;
    }
    .status-menunggu   { background: #fef3c7; color: #92400e; }
    .status-disetujui  { background: #d1fae5; color: #065f46; }
    .status-ditolak    { background: #fee2e2; color: #991b1b; }
    .status-selesai    { background: #dbeafe; color: #1e40af; }
    .status-terjadwal  { background: #e0e7ff; color: #3730a3; }

    .card-hover { transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(15, 23, 42, 0.07); border-color: #dbe4f0; }

    .meta-chip svg { color: #1e40af; }
  </style>
</head>
<body class="bg-gray-100">

  <%- include('../../partials/sidebar', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen">
    <!-- TOP BAR -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
      <div class="flex items-center gap-3 pl-8">
        <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-7 object-contain">
        <div class="w-px h-10 bg-gray-200"></div>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-bold text-gray-800">Data Management</span>
          <span class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">
            Monitoring Pengajuan Sidang
          </span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="flex items-center pr-2">
          <a
            href="/dashboard/pemohon"
            class="flex items-center gap-2.5 bg-blue-50 hover:bg-blue-100 border border-blue-100 rounded-full pl-2 pr-4 py-1.5 transition-colors shadow-sm"
          >
            <span class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center shrink-0">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="7" height="9" x="3" y="3" rx="1"></rect>
                <rect width="7" height="5" x="14" y="3" rx="1"></rect>
                <rect width="7" height="9" x="14" y="12" rx="1"></rect>
                <rect width="7" height="5" x="3" y="16" rx="1"></rect>
              </svg>
            </span>
            <span class="text-xs font-semibold text-blue-700 whitespace-nowrap">
              Dashboard
            </span>
          </a>
        </div>
      </div>
    </div>

    <div class="px-6 py-8" style="padding-left: 64px;">
      <div class="max-w-[1600px] mx-auto">

        <!-- Alert Sukses -->
        <% if (locals.success_msg && success_msg.length > 0) { %>
          <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4 text-green-700 text-sm flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= success_msg %>
          </div>
        <% } %>

        <!-- Filter / Pencarian -->
        <div class="bg-white rounded-2xl border border-gray-200 p-4 mb-6 shadow-sm">
          <div class="flex flex-col sm:flex-row gap-3 items-center justify-between">
            <div class="flex items-center gap-3 w-full sm:w-auto">
              <div class="relative flex-1 sm:flex-none">
                <input type="text" id="searchInput" placeholder="Cari judul atau NIM..."
                       class="w-full sm:w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>
              <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">Semua Status</option>
                <option value="menunggu">Menunggu</option>
                <option value="terjadwal">Terjadwal</option>
                <option value="selesai">Selesai</option>
                <option value="ditolak">Ditolak</option>
              </select>
            </div>
            <a href="/dashboard/pemohon/pengajuan/baru"
               class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition flex items-center justify-center gap-2 shadow-md shadow-blue-200">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Ajukan Sidang Baru
            </a>
          </div>
        </div>

        <!-- Daftar Pengajuan -->
        <div class="space-y-4" id="proposalList">
          <% if (proposals && proposals.length > 0) { %>
            <% proposals.forEach((p) => { 
                // Format the date
                const rawDate = p.tanggalDiajukan ? new Date(p.tanggalDiajukan) : new Date();
                const d = rawDate.getDate().toString().padStart(2, '0');
                const m = (rawDate.getMonth() + 1).toString().padStart(2, '0');
                const y = rawDate.getFullYear();
                const fDate = `${d}/${m}/${y}`;
                
                let badgeClass = '';
                let badgeIcon = '';
                let statusLabel = '';
                
                if (p.statusAdmin === 'terjadwal') {
                  badgeClass = 'status-terjadwal';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>';
                  statusLabel = 'Terjadwal';
                } else if (p.statusAdmin === 'selesai') {
                  badgeClass = 'status-selesai';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>';
                  statusLabel = 'Selesai';
                } else if (p.statusAdmin === 'ditolak' || p.status === 'ditolak') {
                  badgeClass = 'status-ditolak';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>';
                  statusLabel = 'Ditolak';
                } else {
                  badgeClass = 'status-menunggu';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 15"></polyline></svg>';
                  statusLabel = 'Menunggu Persetujuan';
                }
            %>
              <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm card-hover proposal-card" data-status="<%= p.statusAdmin === 'terjadwal' ? 'terjadwal' : (p.statusAdmin === 'selesai' ? 'selesai' : (p.statusAdmin === 'ditolak' || p.status === 'ditolak' ? 'ditolak' : 'menunggu')) %>" data-search="<%= p.judul_karya_akhir.toLowerCase() %> <%= p.nim.toLowerCase() %>">
                <div class="p-6">
                  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex flex-wrap items-center gap-3 mb-3">
                        <h3 class="text-base font-bold text-gray-800"><%= p.judul_karya_akhir %></h3>
                        <span class="status-badge <%= badgeClass %>"><%- badgeIcon %> <%= statusLabel %></span>
                      </div>
                      
                      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-4 gap-y-2.5">
                        <div class="meta-chip flex items-center gap-2 text-sm">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                          <span class="text-gray-400">NIM</span><span class="font-semibold text-gray-700"><%= p.nim %></span>
                        </div>
                        <div class="meta-chip flex items-center gap-2 text-sm">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                          <span class="text-gray-400">Prodi</span><span class="font-semibold text-gray-700"><%= p.program_studi %></span>
                        </div>
                        <div class="meta-chip flex items-center gap-2 text-sm">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                          <span class="text-gray-400">Pembimbing</span><span class="font-semibold text-gray-700"><%= p.dosenPembimbing || 'Belum Ditandatangani' %></span>
                        </div>
                        <div class="meta-chip flex items-center gap-2 text-sm">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                          <span class="text-gray-400">Diajukan</span><span class="font-semibold text-gray-700"><%= fDate %></span>
                        </div>
                        <div class="meta-chip flex items-center gap-2 text-sm">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line></svg>
                          <span class="text-gray-400">Jenis</span><span class="font-semibold text-gray-700"><%= p.jenis_sidang === 'seminar_proposal' ? 'Seminar Proposal' : 'Kolokium' %></span>
                        </div>
                      </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-2 shrink-0">
                      <!-- Detail link can be implemented later if needed -->
                    </div>
                  </div>

                  <!-- Info Sidang (jika terjadwal) -->
                  <% if (p.statusAdmin === 'terjadwal' && p.jadwal) { 
                      const jDateObj = p.jadwal.tanggal ? new Date(p.jadwal.tanggal) : null;
                      let jDate = '-';
                      if (jDateObj) {
                        const days = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
                        jDate = `${days[jDateObj.getDay()]}, ${jDateObj.getDate()} ${jDateObj.toLocaleString('id-ID', {month: 'long'})} ${jDateObj.getFullYear()}`;
                      }
                  %>
                  <div class="mt-4 pt-4 border-t border-gray-100">
                    <div class="rounded-xl border border-gray-200 overflow-hidden">
                      <div class="px-4 py-2.5 flex items-center gap-2" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <h4 class="text-xs font-bold text-white tracking-wide">INFORMASI SIDANG &middot; DARI TIM UPPS</h4>
                      </div>
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 p-4" style="background: #f8fafc;">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                          <div class="flex items-center gap-2 mb-1.5">
                            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg></span>
                            <span class="text-[11px] font-bold uppercase tracking-wide text-gray-500">Jadwal Sidang</span>
                          </div>
                          <p class="text-sm text-gray-800"><span class="text-gray-400">Hari:</span> <span class="font-semibold"><%= jDate %></span></p>
                          <p class="text-sm text-gray-800"><span class="text-gray-400">Pukul:</span> <span class="font-semibold"><%= p.jadwal.jamMulai || '-' %> - <%= p.jadwal.jamSelesai || '-' %> WIB</span></p>
                          <% if (p.jadwal.teknik === 'online') { %>
                            <p class="text-sm text-gray-800"><span class="text-gray-400">Link Meeting:</span> <span class="font-semibold"><%= p.jadwal.linkMeeting || '-' %></span></p>
                          <% } else { %>
                            <p class="text-sm text-gray-800"><span class="text-gray-400">Ruang:</span> <span class="font-semibold"><%= p.jadwal.ruang || '-' %></span></p>
                          <% } %>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200 col-span-2">
                           <div class="flex items-center gap-2 mb-1.5">
                            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg></span>
                            <span class="text-[11px] font-bold uppercase tracking-wide text-gray-500">Penguji & Teknis</span>
                          </div>
                          <p class="text-sm text-gray-800"><span class="text-gray-400">Teknis Sidang:</span> <span class="font-semibold"><%= p.jadwal.teknik === 'online' ? 'Daring (Online)' : 'Luring (Offline)' %></span></p>
                          <%
                            const ketuaList = p.jadwal?.penguji?.filter(x => x.peran === 'Ketua').map(x => x.nama) || [];
                            const anggotaList = p.jadwal?.penguji?.filter(x => x.peran === 'Anggota').map(x => x.nama) || [];
                          %>
                          <p class="text-sm text-gray-800"><span class="text-gray-400">Ketua Penguji:</span> <span class="font-semibold"><%= ketuaList.length > 0 ? ketuaList.join(', ') : '-' %></span></p>
                          <p class="text-sm text-gray-800"><span class="text-gray-400">Anggota Penguji:</span> <span class="font-semibold"><%= anggotaList.length > 0 ? anggotaList.join(', ') : '-' %></span></p>
                        </div>
                      </div>
                    </div>
                  </div>
                  <% } %>

                  <!-- Alasan Penolakan -->
                  <% if (p.statusAdmin === 'ditolak' || p.status === 'ditolak') { %>
                  <div class="mt-4 pt-4 border-t border-gray-100">
                    <div class="flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 p-3.5">
                      <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#fee2e2; color:#991b1b;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      </span>
                      <div>
                        <p class="text-sm text-red-800 font-semibold">Alasan Penolakan</p>
                        <p class="text-sm text-red-700 mt-0.5"><%= p.alasanTolak || p.catatanDospem || 'Terdapat kesalahan pada dokumen.' %></p>
                      </div>
                    </div>
                  </div>
                  <% } %>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="bg-white rounded-2xl border border-gray-200 p-10 text-center shadow-sm">
              <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="text-lg font-bold text-gray-800 mb-2">Belum ada pengajuan sidang</h3>
              <p class="text-sm text-gray-500 mb-6">Anda belum pernah mengajukan sidang. Klik tombol di bawah untuk mulai.</p>
              <a href="/dashboard/pemohon/pengajuan/baru" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-semibold transition inline-flex items-center gap-2 shadow-md shadow-blue-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Ajukan Sidang Baru
              </a>
            </div>
          <% } %>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between mt-6" id="paginationContainer" style="display: none;">
          <p class="text-sm text-gray-500" id="itemsInfo">Menampilkan 0-0 dari 0 data</p>
          <div class="flex gap-2">
            <button id="prevBtn" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition disabled:opacity-50">Previous</button>
            <div id="pageNumbers" class="flex gap-2"></div>
            <button id="nextBtn" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition disabled:opacity-50">Next</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('searchInput');
      const statusFilter = document.getElementById('statusFilter');
      const cards = Array.from(document.querySelectorAll('.proposal-card'));
      
      const itemsInfo = document.getElementById('itemsInfo');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const pageNumbers = document.getElementById('pageNumbers');
      const paginationContainer = document.getElementById('paginationContainer');
      
      const ITEMS_PER_PAGE = 5;
      let currentPage = 1;
      let filteredCards = [...cards];
      
      function renderPagination() {
        if (filteredCards.length === 0) {
          paginationContainer.style.display = 'none';
          cards.forEach(c => c.style.display = 'none');
          return;
        }
        
        paginationContainer.style.display = 'flex';
        const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
        
        // Ensure currentPage is valid
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;
        
        // Hide all cards first
        cards.forEach(c => c.style.display = 'none');
        
        // Show cards for current page
        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const currentCards = filteredCards.slice(start, end);
        currentCards.forEach(c => c.style.display = 'block');
        
        // Update info text
        itemsInfo.textContent = `Menampilkan ${start + 1}-${Math.min(end, filteredCards.length)} dari ${filteredCards.length} data`;
        
        // Update buttons
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages;
        
        // Render page numbers
        pageNumbers.innerHTML = '';
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          if (i === currentPage) {
            btn.className = 'px-3 py-1.5 bg-blue-600 text-white rounded-lg text-sm font-semibold shadow-sm';
          } else {
            btn.className = 'px-3 py-1.5 border border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition';
          }
          btn.textContent = i;
          btn.addEventListener('click', () => {
            currentPage = i;
            renderPagination();
          });
          pageNumbers.appendChild(btn);
        }
      }
      
      function filterData() {
        const searchTerm = searchInput.value.toLowerCase();
        const statusTerm = statusFilter.value;
        
        filteredCards = cards.filter(card => {
          const cardSearch = card.getAttribute('data-search') || '';
          const cardStatus = card.getAttribute('data-status') || '';
          
          const matchSearch = cardSearch.includes(searchTerm);
          const matchStatus = statusTerm === '' || cardStatus === statusTerm;
          
          return matchSearch && matchStatus;
        });
        
        currentPage = 1;
        renderPagination();
      }
      
      searchInput.addEventListener('input', filterData);
      statusFilter.addEventListener('change', filterData);
      
      prevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          renderPagination();
        }
      });
      
      nextBtn.addEventListener('click', () => {
        const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
        if (currentPage < totalPages) {
          currentPage++;
          renderPagination();
        }
      });
      
      // Init
      renderPagination();
    });
  </script>
</body>
</html>
